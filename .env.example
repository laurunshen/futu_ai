# OpenD connection
FUTU_OPEND_HOST=127.0.0.1
FUTU_OPEND_PORT=11111

# The Futu Python SDK writes logs under $HOME/.com.futunn.FutuOpenD/Log.
# By default this project points HOME to .runtime/home before importing futu,
# so SDK logs stay inside this project. Set this to true only if you prefer
# the SDK's default home-directory behavior.
FUTU_USE_SYSTEM_HOME=false

# Leave empty to use the SDK default. Common values:
# FUTUSECURITIES, FUTUINC, FUTUSG, FUTUAU, FUTUCA, FUTUMY, FUTUJP
FUTU_SECURITY_FIRM=

# Use account id if you know it. Otherwise OpenD uses account index 0.
FUTU_ACCOUNT_ID=0
FUTU_ACCOUNT_INDEX=0

# Paper-only risk controls
FUTU_ALLOWED_MARKETS=US,HK,CN
FUTU_ALLOWED_CODES=US.AAPL,HK.00700,SH.600519,SZ.000001
FUTU_REQUIRE_WHITELIST=true
FUTU_ALLOW_SELL=true
FUTU_ALLOW_MARKET_ORDERS=false

# Local-currency caps by market. US=USD, HK=HKD, CN=CNY/CNH display.
FUTU_MAX_ORDER_VALUE_US=1000
FUTU_MAX_ORDER_VALUE_HK=10000
FUTU_MAX_ORDER_VALUE_CN=10000
FUTU_MAX_QTY_US=10
FUTU_MAX_QTY_HK=1000
FUTU_MAX_QTY_CN=1000

# Gemini AI decision engine
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_AUTO_ENABLED=false
GEMINI_AUTO_EXECUTE=false
GEMINI_OBSERVE_MARKETS=US,HK
GEMINI_EXECUTE_MARKETS=US
GEMINI_CONFIDENCE_THRESHOLD=70
GEMINI_MAX_NOTIONAL_US=300
GEMINI_MAX_NOTIONAL_HK=1000
GEMINI_MAX_TRADES_PER_DAY=3
GEMINI_COOLDOWN_MINUTES=60
GEMINI_LOOP_INTERVAL_SECONDS=1800
